{
	"name": "@agentaos/crypto",
	"version": "1.1.1",
	"description": "CGGMP24 threshold ECDSA WASM module for AgentaOS",
	"license": "Apache-2.0",
	"author": "AgentaOS <hello@agentaos.ai>",
	"repository": {
		"type": "git",
		"url": "https://github.com/AgentaOS/agentaos.git",
		"directory": "packages/mpc-wasm"
	},
	"homepage": "https://github.com/AgentaOS/agentaos",
	"bugs": "https://github.com/AgentaOS/agentaos/issues",
	"keywords": ["threshold", "wallet", "mpc", "cggmp24", "ecdsa", "wasm", "secp256k1"],
	"type": "module",
	"main": "./pkg/agentaos_mpc_wasm.js",
	"types": "./pkg/agentaos_mpc_wasm.d.ts",
	"exports": {
		".": {
			"types": "./pkg/agentaos_mpc_wasm.d.ts",
			"import": "./pkg/agentaos_mpc_wasm.js"
		},
		"./web": {
			"types": "./pkg-web/agentaos_mpc_wasm.d.ts",
			"import": "./pkg-web/agentaos_mpc_wasm.js"
		}
	},
	"files": ["pkg", "pkg-web"],
	"engines": {
		"node": ">=20.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "bash build-node.sh && bash build-web.sh",
		"build:node": "bash build-node.sh",
		"build:web": "bash build-web.sh",
		"prepack": "rm -f pkg/.gitignore pkg-web/.gitignore",
		"clean": "rm -rf pkg pkg-web target"
	}
}
