{
	"name": "@agentaos/chains",
	"version": "1.2.0",
	"description": "Ethereum chain adapter for AgentaOS threshold wallet",
	"license": "Apache-2.0",
	"author": "AgentaOS <hello@agentaos.ai>",
	"repository": {
		"type": "git",
		"url": "https://github.com/AgentaOS/agentaos.git",
		"directory": "packages/chains"
	},
	"homepage": "https://github.com/AgentaOS/agentaos",
	"bugs": "https://github.com/AgentaOS/agentaos/issues",
	"keywords": ["threshold", "wallet", "ethereum", "chain", "viem", "agent"],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": ["dist"],
	"engines": {
		"node": ">=20.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc",
		"lint": "biome check src/",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@agentaos/core": "workspace:*",
		"viem": "^2.21.0"
	},
	"devDependencies": {}
}
