{
	"name": "@agentaos/engine",
	"version": "1.2.0",
	"description": "CGGMP24 threshold ECDSA signing scheme (WASM)",
	"license": "Apache-2.0",
	"author": "AgentaOS <hello@agentaos.ai>",
	"repository": {
		"type": "git",
		"url": "https://github.com/AgentaOS/agentaos.git",
		"directory": "packages/schemes"
	},
	"homepage": "https://github.com/AgentaOS/agentaos",
	"bugs": "https://github.com/AgentaOS/agentaos/issues",
	"keywords": ["threshold", "wallet", "mpc", "ecdsa", "cggmp24", "wasm", "signing"],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": ["dist"],
	"engines": {
		"node": ">=20.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc",
		"lint": "biome check src/",
		"test": "vitest run --passWithNoTests --exclude='**/*.integration.test.*'",
		"test:integration": "vitest run --testPathPattern=integration",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@noble/curves": "^2.0.1",
		"@agentaos/core": "workspace:*",
		"@agentaos/crypto": "workspace:*",
		"viem": "^2.47.10"
	},
	"devDependencies": {}
}
